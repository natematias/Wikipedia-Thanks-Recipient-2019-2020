	year = {2020},
	note = {Accepted: 2020-12-15T13:31:29Z},
	keywords = {Computers, Digital \& Online Resources, General, Information and Interdisciplinary subjects::GL Library and information sciences / Museology::GLF IT, Internet, Internet and electronic resources in libraries, Language Arts \& Disciplines, Library \& Information Science, thema EDItEUR::G Reference, thema EDItEUR::U Computing and Information Technology::UB Information technology: general topics::UBW Internet: general works, thema EDItEUR::U Computing and Information Technology::UD Digital Lifestyle and online world: consumer and user guides, User-generated Content},
