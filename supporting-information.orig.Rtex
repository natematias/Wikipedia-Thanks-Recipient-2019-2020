<<init, echo=FALSE, results='hide'>>=
load("data/paper-data.RData")
load("data/ITT_table.RData")
all.cace.df <-  cbind(factor = rownames(all.cace.df), all.cace.df)
all.newcomer.cace.df <-  cbind(factor = rownames(all.newcomer.cace.df), all.newcomer.cace.df)

# Smart number formatter: 2dp, but 4dp if rounds to 0.00
fmt <- function(x) {
  sapply(x, function(v) {
    if (is.na(v)) return("--")
    if (v == 0) return("0")
    if (abs(v) >= 0.005) return(sprintf("%.2f", v))
    if (abs(v) >= 0.00005) return(sprintf("%.4f", v))
    return(sprintf("%.2e", v))
  })
}

# Smart p-value formatter
fmt_p <- function(p) {
  sapply(p, function(v) {
    if (is.na(v)) return("--")
    if (v < 0.0001) return("$<$0.0001")
    if (v < 0.001)  return(sprintf("%.4f", v))
    if (v < 0.01)   return(sprintf("%.3f", v))
    return(sprintf("%.2f", v))
  })
}
